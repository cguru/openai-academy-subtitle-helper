{
  "manifest_version": 3,
  "name": "OpenAI Academy Subtitle Helper",
  "version": "0.1.0",
  "description": "Local subtitle viewer and translator helper for OpenAI Academy.",
  "key": "",
  "permissions": ["activeTab", "nativeMessaging", "storage", "tabs"],
  "host_permissions": ["https://academy.openai.com/*", "https://player.vimeo.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "OpenAI Academy Subtitle Helper",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://academy.openai.com/*", "https://player.vimeo.com/*"],
      "js": ["src/content-script.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
